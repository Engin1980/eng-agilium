{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Serilog.AspNetCore.RequestLoggingMiddleware": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss}] [{SourceContext,-15}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": ".logs/app-log.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:HH:mm:ss}] [{SourceContext,-25}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "(override)"
  },
  "AppSettings": {
    "FrontendBaseUrl": "https://localhost:5173",
    "UseSwagger": true,
    "Security": {
      "Jwt": {
        "Key": "ThisIsASecretKeyForJWT-ThisIsASecretKeyForJWT-ThisIsASecretKeyForJWT",
        "Issuer": "Eng.Agilium.Be"
      },
      "Tokens": {
        "AccessTokenExpirationMinutes": 15,
        "RefreshTokenExpirationMinutes": 7,
        "RefreshTokenLength": 7,
        "PasswordResetTokenExpirationMinutes": 15,
        "PasswordResetTokenLength": 32
      },
      "Turnstile": {
        "Enabled": true,
        "SecretKey": "ThisIsASecretKeyForTurnstile-ThisIsASecretKeyForTurnstile-ThisIsASecretKeyForTurnstile"
      },
      "Password": {
        "MaxFailedLoginAttempts": 5,
        "LockoutDurationMinutes": 15
      },
      "RequestLimiter": {
        "WindowLength": 10,
        "SegmentsPerWindow": 5,
        "PermitLimit": 100,
        "QueueLimit": 20
      },
      "EnableTestingEndpoints": false
    },
    "Email": {
      "Smtp": {
        "Host": "mailer2.osu.cz",
        "Port": 587,
        "Username": "(override)",
        "Password": "(override)"
      },
      "DebugRecipient": null
    }
  }
}
