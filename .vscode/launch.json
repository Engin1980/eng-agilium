{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BE",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-net",
      "program": "${workspaceFolder}/Agilium.Be/bin/Debug/net8.0/Agilium.Be.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Agilium.Be",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      }
    }
  ]
}